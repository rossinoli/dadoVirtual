<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E0E0E0"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="74dp">

        <TextView
            android:id="@+id/textTituloMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:text="DADO.GO"
            android:textColor="#333333"
            android:textSize="32sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alignmentMode="alignMargins"
            android:columnCount="2">

            <ImageButton
                android:id="@+id/btnMenuD4"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_margin="10dp"
                android:background="#FFFFFF"
                android:elevation="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/d4" />

            <ImageButton
                android:id="@+id/btnMenuD6"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_margin="10dp"
                android:background="#FFFFFF"
                android:elevation="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/d6_6" />

            <ImageButton
                android:id="@+id/btnMenuD8"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_margin="10dp"
                android:background="#FFFFFF"
                android:elevation="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/d8" />

            <ImageButton
                android:id="@+id/btnMenuD10"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_margin="10dp"
                android:background="#FFFFFF"
                android:elevation="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/d10" />

            <ImageButton
                android:id="@+id/btnMenuD12"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_margin="10dp"
                android:background="#FFFFFF"
                android:elevation="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/d12" />

            <ImageButton
                android:id="@+id/btnMenuD20"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_margin="10dp"
                android:background="#FFFFFF"
                android:elevation="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/d20" />

        </GridLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>